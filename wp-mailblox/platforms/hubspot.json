{
    "system_tags": {
        "UNSUB": {
            "tag": "{{ unsubscribe_link }}",
            "type": "url",
            "label": "Unsubscribe URL"
        },
        "WEBVERSION": {
            "tag": "{{ view_as_page_link }}",
            "type": "url",
            "label": "View Online URL"
        },
        "ARCHIVE": {
            "tag": "{{ view_as_page_link }}",
            "type": "url",
            "label": "Web Version URL"
        },
        "SUBJECT": {
            "tag": "{{ content.subject }}",
            "type": "text",
            "label": "Email Subject"
        },
        "EMAIL": {
            "tag": "{{ contact.email }}",
            "type": "text",
            "label": "Email Address"
        },
        "OFFICE_LOCATION": {
            "tag": "{{ office_location_address }}",
            "type": "text",
            "label": "Office Location Address"
        }
    },
    "audience_tags": {
        "FNAME": {
            "tag": "{{ contact.firstname }}",
            "type": "text",
            "label": "First Name"
        },
        "LNAME": {
            "tag": "{{ contact.lastname }}",
            "type": "text",
            "label": "Last Name"
        },
        "FULLNAME": {
            "tag": "{{ contact.firstname }} {{ contact.lastname }}",
            "type": "text",
            "label": "Full Name"
        },
        "PHONE": {
            "tag": "{{ contact.phone }}",
            "type": "text",
            "label": "Phone Number"
        },
        "COMPANY": {
            "tag": "{{ contact.company }}",
            "type": "text",
            "label": "Company"
        },
        "CITY": {
            "tag": "{{ contact.city }}",
            "type": "text",
            "label": "City"
        },
        "COUNTRY": {
            "tag": "{{ contact.country }}",
            "type": "text",
            "label": "Country"
        },
        "JOB_TITLE": {
            "tag": "{{ contact.jobtitle }}",
            "type": "text",
            "label": "Job Title"
        }
    },
    "owner_tags": {
        "OWNER_FNAME": {
            "tag": "{{ owner.firstname }}",
            "type": "text",
            "label": "Owner First Name"
        },
        "OWNER_LNAME": {
            "tag": "{{ owner.lastname }}",
            "type": "text",
            "label": "Owner Last Name"
        },
        "OWNER_EMAIL": {
            "tag": "{{ owner.email }}",
            "type": "text",
            "label": "Owner Email"
        },
        "OWNER_PHONE": {
            "tag": "{{ owner.phone }}",
            "type": "text",
            "label": "Owner Phone"
        }
    },
    "conditional_tags": {
        "IF": {
            "tag": "{% if contact.firstname %}",
            "type": "text",
            "label": "Conditional If"
        },
        "ELSE": {
            "tag": "{% else %}",
            "type": "text",
            "label": "Conditional Else"
        },
        "END_IF": {
            "tag": "{% endif %}",
            "type": "text",
            "label": "Conditional End If"
        }
    },
    "conditional_fields": {
        "FNAME":   { "if": "{% if contact.firstname %}", "endif": "{% endif %}", "label": "First Name" },
        "LNAME":   { "if": "{% if contact.lastname %}",  "endif": "{% endif %}", "label": "Last Name" },
        "COMPANY": { "if": "{% if contact.company %}",   "endif": "{% endif %}", "label": "Company" },
        "PHONE":   { "if": "{% if contact.phone %}",     "endif": "{% endif %}", "label": "Phone Number" },
        "CITY":    { "if": "{% if contact.city %}",      "endif": "{% endif %}", "label": "City" },
        "COUNTRY": { "if": "{% if contact.country %}",   "endif": "{% endif %}", "label": "Country" }
    }
}