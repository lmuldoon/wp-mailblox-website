{
    "system_tags": {
        "UNSUB": {
            "tag": "{{ event.UnsubscribeURL }}",
            "type": "url",
            "label": "Unsubscribe URL"
        },
        "WEBVERSION": {
            "tag": "{{ event.ViewEmailURL }}",
            "type": "url",
            "label": "View Online URL"
        },
        "ARCHIVE": {
            "tag": "{{ event.ViewEmailURL }}",
            "type": "url",
            "label": "Web Version URL"
        },
        "SUBJECT": {
            "tag": "{{ event.SubjectLine }}",
            "type": "text",
            "label": "Email Subject"
        },
        "EMAIL": {
            "tag": "{{ person.Email }}",
            "type": "text",
            "label": "Email Address"
        }
    },
    "audience_tags": {
        "FNAME": {
            "tag": "{{ person.first_name }}",
            "type": "text",
            "label": "First Name"
        },
        "LNAME": {
            "tag": "{{ person.last_name }}",
            "type": "text",
            "label": "Last Name"
        },
        "FULLNAME": {
            "tag": "{{ person.first_name }} {{ person.last_name }}",
            "type": "text",
            "label": "Full Name"
        },
        "PHONE": {
            "tag": "{{ person.phone_number }}",
            "type": "text",
            "label": "Phone Number"
        },
        "CITY": {
            "tag": "{{ person.city }}",
            "type": "text",
            "label": "City"
        },
        "COUNTRY": {
            "tag": "{{ person.country }}",
            "type": "text",
            "label": "Country"
        },
        "COMPANY": {
            "tag": "{{ person.organization }}",
            "type": "text",
            "label": "Company / Organisation"
        }
    },
    "ecommerce_tags": {
        "TOTAL_SPENT": {
            "tag": "{{ person.total_spent }}",
            "type": "text",
            "label": "Total Amount Spent"
        },
        "ORDERS": {
            "tag": "{{ person.total_orders }}",
            "type": "text",
            "label": "Number of Orders"
        },
        "LAST_ORDER_DATE": {
            "tag": "{{ person.last_order_date }}",
            "type": "text",
            "label": "Last Order Date"
        }
    },
    "conditional_tags": {
        "IF": {
            "tag": "{% if person.first_name %}",
            "type": "text",
            "label": "Conditional If"
        },
        "ELSE": {
            "tag": "{% else %}",
            "type": "text",
            "label": "Conditional Else"
        },
        "END_IF": {
            "tag": "{% endif %}",
            "type": "text",
            "label": "Conditional End If"
        }
    },
    "conditional_fields": {
        "FNAME":   { "if": "{% if person.first_name %}",    "endif": "{% endif %}", "label": "First Name" },
        "LNAME":   { "if": "{% if person.last_name %}",     "endif": "{% endif %}", "label": "Last Name" },
        "COMPANY": { "if": "{% if person.organization %}",  "endif": "{% endif %}", "label": "Company" },
        "PHONE":   { "if": "{% if person.phone_number %}", "endif": "{% endif %}", "label": "Phone Number" },
        "CITY":    { "if": "{% if person.city %}",          "endif": "{% endif %}", "label": "City" },
        "COUNTRY": { "if": "{% if person.country %}",       "endif": "{% endif %}", "label": "Country" }
    }
}