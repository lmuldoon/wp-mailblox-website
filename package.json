    "@vue/compiler-sfc": "^3.2.29",
    "@wordpress/eslint-plugin": "^7.4.0",
    "autoprefixer": "^10.2.1",
    "babel-loader": "^8.2.2",
    "babel-plugin-transform-runtime": "^6.23.0",
    "browser-sync": "^2.26.13",
    "browser-sync-webpack-plugin": "^2.3.0",
    "copy-webpack-plugin": "^7.0.0",
    "css-loader": "^5.0.1",
    "eslint": "^7.17.0",
